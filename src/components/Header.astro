---
import '../styles/variables.css';
import { fileUrl, type SiteConfigRecord } from '../lib/pocketbase';

interface Props { siteConfig: SiteConfigRecord | null }
const { siteConfig } = Astro.props;

const backgroundUrl = siteConfig?.image_header ? fileUrl(siteConfig, siteConfig.image_header, '1800x0') : '';
const titre = siteConfig?.header_titre || 'ETHAN LEDOUX';
const sousTitre = siteConfig?.header_sous_titre || 'JOKHAN FILM PRODUCTION';
---

<header>
    <div class="header">
        {backgroundUrl && (
            <img src={backgroundUrl} alt="" class="background" loading="eager" />
        )}
        <div class="content">
            <h1 class="header-title">{titre}</h1>
            <p>{sousTitre}</p>
        </div>
    </div>
</header>
<div class="navigation-menu">
    <nav style="transform: translateY(-50%);">
        <a href="/" class="button">ACCUEIL</a>
        <a href="/catalogue" class="button">MES FILMS</a>
        <a href="/contact" class="button">SOUTIEN</a>
    </nav>
</div>

<style>
    header {
        position: relative;
        padding: 0 10px;
        text-align: center;
        color: var(--light-inerted-background-color);
        z-index: 0;
        height: 500px;

        display: flex;
        justify-content: center;
        align-items: center;
        flex-direction: column;
    }
    
    header .background {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: brightness(var(--imageAlpha));
        z-index: -1;
    }

    header .content .header-title {
        margin: 0;
        font-size: 3em;
        font-weight: bold;
    }

    header .content p {
        margin: 10px 0 0;
        font-size: 1.3em;
    }

    .navigation-menu {  
        height: 0;
        display: grid;
        justify-content: center;
        z-index: 2;
    }

    .navigation-menu nav {  
        text-align: center;
        background: var(--light-big-gray);
        padding: 10px 15px;
    }

    .navigation-menu nav a.button {
        display: inline-block;
        padding: 10px 20px;
        color: var(--light-inerted-background-color);
        text-decoration: none;
        border-radius: 5px;
    }

    .navigation-menu nav a.button:hover {
        color: var(--light-link-hover-color);
    }
</style>